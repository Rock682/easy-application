{
  "name": "easy-applications",
  "private": true,
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i css/tailwind-input.css -o css/tailwind.min.css --minify",
    "build:images": "node scripts/optimize-images.js",
    "upgrade": "node scripts/upgrade-all.js",
    "inject:ads": "node scripts/inject-ads.js",
    "restructure:exams": "node scripts/restructure-exam-pages.js",
    "sitemap": "node scripts/generate-sitemap.js",
    "build": "npm run build:css && npm run build:images && npm run upgrade && npm run inject:ads && npm run sitemap"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.1.0"
  }
}